{
  "name": "tether",
  "displayName": "Tether",
  "description": "Control Antigravity AI remotely from your phone — send prompts, detect completion, accept changes",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Tether",
      "properties": {
        "tether.relayUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL of the Tether relay server (e.g. https://tether-relay.onrender.com)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tether-sidebar",
          "title": "Tether",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "tether-sidebar": [
        {
          "type": "webview",
          "id": "tether.sidebarView",
          "name": "Connection"
        }
      ]
    },
    "commands": [
      {
        "command": "tether.sendToNewChat",
        "title": "Tether: Send to NEW Chat"
      },
      {
        "command": "tether.sendToExistingChat",
        "title": "Tether: Send to EXISTING Chat"
      },
      {
        "command": "tether.acceptChanges",
        "title": "Tether: Accept ALL Changes"
      },
      {
        "command": "tether.rejectChanges",
        "title": "Tether: Reject ALL Changes"
      },
      {
        "command": "tether.control",
        "title": "Tether: Open Control Panel"
      },
      {
        "command": "tether.listOpenFiles",
        "title": "Tether: List OPEN Files"
      },
      {
        "command": "tether.listWorkspaceFiles",
        "title": "Tether: List WORKSPACE Files"
      },
      {
        "command": "tether.peekFileContent",
        "title": "Tether: Peek File Content"
      },
      {
        "command": "tether.sendPromptWithFile",
        "title": "Tether: Send Prompt with File Context"
      },
      {
        "command": "tether.runShellCommand",
        "title": "Tether: Run Shell Command"
      },
      {
        "command": "tether.sendToTerminal",
        "title": "Tether: Send to Active Terminal"
      },
      {
        "command": "tether.peekActiveTerminal",
        "title": "Tether: Peek Active Terminal"
      },
      {
        "command": "tether.checkStatus",
        "title": "Tether: Check Status"
      },
      {
        "command": "tether.startWatching",
        "title": "Tether: Start Watching"
      },
      {
        "command": "tether.testGetDiff",
        "title": "Tether: 🧪 Test Get Diff (debug)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/qrcode": "^1.5.6",
    "@types/vscode": "^1.109.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "ws": "^8.19.0"
  }
}
